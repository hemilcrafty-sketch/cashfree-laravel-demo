{
	"info": {
		"_postman_id": "cf-payment-demo-v2025",
		"name": "Cashfree PG v2025-01-01 Integration",
		"description": "Updated API collection for the direct REST API integration (v2025-01-01). This collection maps to the new /api/payments/* routes.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Create Order",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"amount\": 1.00,\n    \"email\": \"customer@example.com\",\n    \"phone\": \"9876543210\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/create-order",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"payments",
						"create-order"
					]
				},
				"description": "Creates a new order in both the local database and Cashfree. Returns the payment_session_id needed for the frontend SDK."
			},
			"response": []
		},
		{
			"name": "2. Get Local Order Status",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/payments/ORD_YOUR_ID",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"payments",
						"ORD_YOUR_ID"
					]
				},
				"description": "Fetches the current status of an order from your local database."
			},
			"response": []
		},
		{
			"name": "3. Sync/Verify Order (Fetch from Cashfree)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/payments/verify/ORD_YOUR_ID",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"payments",
						"verify",
						"ORD_YOUR_ID"
					]
				},
				"description": "Fetches the latest status directly from Cashfree and updates your local database record."
			},
			"response": []
		},
		{
			"name": "4. Webhook Simulation (v5 format)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"data\": {\n        \"order\": {\n            \"order_id\": \"ORD_YOUR_ID\"\n        },\n        \"payment\": {\n            \"payment_status\": \"SUCCESS\",\n            \"cf_payment_id\": \"PAY_99887766\"\n        }\n    }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/payments/webhook",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"payments",
						"webhook"
					]
				},
				"description": "Simulates a Cashfree webhook notification. Use this to test your backend's ability to handle asynchronous updates."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000"
		}
	]
}
